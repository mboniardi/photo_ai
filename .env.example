# Copia questo file in .env e compila i valori
# cp .env.example .env && nano .env

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Sessioni (stringa casuale, es: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME

# Gemini AI (free tier)
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=

# Gemini AI (paid tier — stessa libreria/modello, limiti più alti)
GEMINI_PAID_API_KEY=CHANGE_ME

# Groq (alternativa a Gemini, free tier generoso — console.groq.com)
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_SIDE_PX=768   # ridotto per risparmiare token (free tier: 500k TPD)

# Estensioni da escludere dalla scansione (es. ".cr3,.nef")
EXCLUDED_EXTS=

# Path dati
APP_DATA_PATH=/mnt/nas/photo_ai_data
LOCAL_DB=/opt/photo_ai/data/photo_ai.db
PHOTOS_PATH=/mnt/nas
AUTHORIZED_EMAILS_PATH=/opt/photo_ai/data/authorized_emails.txt

# NAS (usato da fstab — non letto dall'app direttamente)
NAS_CIFS_USER=CHANGE_ME
NAS_CIFS_PASSWORD=CHANGE_ME

# Porta applicazione
APP_PORT=8080
