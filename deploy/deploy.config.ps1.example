# deploy.config.ps1.example
# Copy this file to deploy.config.ps1 and fill in your values.
# DO NOT commit deploy.config.ps1 to git — it contains secrets.

# ── Rete ────────────────────────────────────────────────────────
$VM_STATIC_IP      = "192.168.1.100"
$VM_GATEWAY        = "192.168.1.1"
$VM_DNS            = "192.168.1.1"
$VM_NETMASK        = "24"
$HYPERV_SWITCH     = "Default Switch"

# ── VM ──────────────────────────────────────────────────────────
$VM_NAME_PREFIX    = "PhotoAI"
$VM_RAM_GB         = 2
$VM_CPU_COUNT      = 2
$VM_DISK_GB        = 20
$VM_GEN            = 2

# ── NAS ─────────────────────────────────────────────────────────
$NAS_SERVER        = "192.168.1.10"          # hostname o IP del NAS/PC che espone la share SMB
$NAS_SHARE         = "foto"                  # nome della share SMB (es. "Media")
$NAS_PHOTOS_SUBDIR = "photos"                # sottocartella dentro la share dove stanno le foto (lascia vuoto se le foto sono nella root della share)
$NAS_USER          = "nasuser"
$NAS_PASSWORD      = "CHANGE_ME"

# ── App ─────────────────────────────────────────────────────────
$APP_PORT          = 8080
$APP_GIT_REPO      = "https://github.com/YOUR_USERNAME/photo_ai.git"
$APP_GIT_BRANCH    = "main"

# ── Secrets ─────────────────────────────────────────────────────
$GOOGLE_CLIENT_ID     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
$GOOGLE_CLIENT_SECRET = "CHANGE_ME"
$GEMINI_API_KEY       = "CHANGE_ME"
$GEMINI_PAID_API_KEY  = ""              # opzionale — stessa libreria, limiti più alti
$GROQ_API_KEY         = "CHANGE_ME"         # da console.groq.com — free tier, no carta di credito
$AUTHORIZED_EMAILS    = @("your@gmail.com")
$EXCLUDED_EXTS        = ".cr3"              # estensioni da escludere dalla scansione (es. ".cr3,.nef")

# ── VM console password (for SSH/console access during testing) ──
$CONSOLE_PASSWD       = "CHANGE_ME"

# ── Health check ────────────────────────────────────────────────
$HEALTH_TIMEOUT_SEC   = 900
$HEALTH_INTERVAL_SEC  = 10
